x = as.numeric(as.character(Dist)),
y = z_star,
color = Flag_Type
)
) +
geom_point(
size = 2.3,
alpha = 0.85,
position = position_jitter(
width = 0.15,
height = 0
)
) +
scale_color_manual(
values = flag_colors,
limits = flag_levels,
drop = FALSE
) +
facet_wrap(
~ Tran
) +
flag_theme +
labs(
title = "Elevation and Distance of Flagged Observations",
subtitle = "Only observations with recorded QC flags are shown",
x = "Distance from Marsh Edge (m)",
y = expression("Elevation (" * z^"*" * ")"),
color = "Flag Type"
)
cm_flags_z_distance
#############################################################
# 7. TIMELINE OF FLAG COUNTS BY TRANSECT
#
# Tile fill represents the total number of recorded flags,
# avoiding overlap when several flags occur on one date.
#############################################################
flag_totals_day <- flagged_cm |>
count(
Tran,
Date.removed.from.field,
name = "total_flags"
)
cm_flag_timeline <- ggplot(
flag_totals_day,
aes(
x = Date.removed.from.field,
y = Tran,
fill = total_flags
)
) +
geom_tile(
color = "white",
height = 0.8
) +
scale_fill_gradient(
low = "grey95",
high = "#4D4D4D"
) +
scale_x_date(
date_breaks = "1 month",
date_labels = "%b %Y"
) +
flag_theme +
theme(
axis.text.x = element_text(
angle = 45,
hjust = 1
),
panel.grid = element_blank()
) +
labs(
title = "Total QC Flags Through Time by Transect",
x = "Date Removed from Field",
y = NULL,
fill = "Total Flags"
)
cm_flag_timeline
#############################################################
# 8. FLAG COMPOSITION BY DATE AND TRANSECT
#
# A stacked bar is more appropriate than overlapping tiles
# for showing proportions of several flag types.
#############################################################
cm_flag_proportions <- ggplot(
flag_props_day,
aes(
x = Date.removed.from.field,
y = prop,
fill = Flag_Type
)
) +
geom_col(
width = 20
) +
scale_fill_manual(
values = flag_colors,
limits = flag_levels,
drop = FALSE
) +
scale_y_continuous(
labels = scales::percent_format()
) +
scale_x_date(
date_breaks = "1 month",
date_labels = "%b %Y"
) +
facet_wrap(
~ Tran,
ncol = 1
) +
flag_theme +
theme(
axis.text.x = element_text(
angle = 45,
hjust = 1
)
) +
labs(
title = "Composition of QC Flags by Date and Transect",
x = "Date Removed from Field",
y = "Percentage of Recorded Flags",
fill = "Flag Type"
)
cm_flag_proportions
#############################################################
# 9. FLAG CO-OCCURRENCE MATRIX
#
# This section uses the original wide cm_z_flux dataset.
#############################################################
flag_matrix <- cm_z_flux |>
select(
all_of(flag_cols)
) |>
mutate(
across(
everything(),
~ as.integer(replace_na(.x, 0) == 1)
)
) |>
as.matrix()
co_occurrence <- t(flag_matrix) %*% flag_matrix
co_occurrence_df <- as.data.frame(co_occurrence) |>
rownames_to_column("Flag_Code_1") |>
pivot_longer(
cols = -Flag_Code_1,
names_to = "Flag_Code_2",
values_to = "n"
) |>
mutate(
Flag_1 = recode(
Flag_Code_1,
!!!flag_labels
),
Flag_2 = recode(
Flag_Code_2,
!!!flag_labels
),
Flag_1 = factor(
Flag_1,
levels = flag_levels
),
Flag_2 = factor(
Flag_2,
levels = flag_levels
)
)
cm_flag_cooccurrence <- ggplot(
co_occurrence_df,
aes(
x = Flag_1,
y = Flag_2,
fill = n
)
) +
geom_tile(
color = "white"
) +
geom_text(
aes(label = n),
size = 3
) +
scale_fill_gradient(
low = "grey95",
high = "#7570B3"
) +
coord_equal() +
flag_theme +
theme(
axis.text.x = element_text(
angle = 45,
hjust = 1
)
) +
labs(
title = "QC Flag Co-occurrence Matrix",
x = NULL,
y = NULL,
fill = "Co-occurrences"
)
cm_flag_cooccurrence
#############################################################
