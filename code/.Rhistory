library(ggdist)
library(ggplot2)
b_data2 = ggplot(
buckslanding_data %>% filter(Flux >= 0),
aes(
x = Study.Phase,
y = Flux,
fill = Study.Phase
)
) +
ggdist::stat_halfeye(
adjust = 0.5,
width = 0.6,
justification = -0.2,
alpha = 0.7
) +
geom_boxplot(
width = 0.15,
outlier.shape = NA,
alpha = 0.5
) +
geom_jitter(
width = 0.05,
alpha = 0.3,
size = 1
) +
theme_minimal() +
labs(
title = "Buck's Landing",
x = "Study Phase",
y = expression(Flux~(g/m^3))
) +
theme(legend.position = "none")
