y = Study.Phase,
fill = Study.Phase
)
) +
geom_density_ridges(alpha = 0.7, scale = 1.2) +
theme_ridges() +
labs(
title = "Buck's Landing",
x = expression(Flux~(g/m^3)),
y = "Study Phase"
) +
theme(legend.position = "none")
b_raincloud
