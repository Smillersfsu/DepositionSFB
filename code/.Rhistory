),
alpha = 0.95,
size = 3,
stroke = 1.1,
position = position_jitter(
width = 2,
height = 0
)
) +
scale_color_manual(
values = flag_colors,
limits = flag_levels,
drop = FALSE,
name = "QC Flag"
) +
scale_shape_manual(
values = flag_shapes,
