# Consistent shapes for each flag type
flag_shapes <- c(
"Filter Issues"                   = 16, # filled circle
"Rubber Band Issues"              = 17, # filled triangle
"Flood/Ponding"                   = 15, # filled square
"Biological Matter"               = 18, # filled diamond
"Recorded Drop in Field/Lab"      = 8,  # star
"Open Ziploc Bag Observed"        = 3,  # plus
"Position Changed"                = 4,  # x
"Multiple Drying Times Needed"    = 7,  # square cross
"Negative Flux Values Calculated" = 1   # open circle
)
cm_z_flux <- cm_z_flux %>%
mutate(
Dist_numeric = readr::parse_number(as.character(Dist))
)
flagged_cm <- flagged_cm %>%
mutate(
Dist_numeric = readr::parse_number(as.character(Dist))
)
flux_flags_distance <- ggplot() +
# All observations in gray
geom_point(
data = cm_z_flux,
aes(
x = Dist_numeric,
y = Flux
),
color = "grey75",
shape = 16,
alpha = 0.4,
size = 2,
position = position_jitter(
width = 0.15,
height = 0
)
) +
# Flagged observations by color and shape
geom_point(
data = flagged_cm,
aes(
x = Dist_numeric,
y = Flux,
color = Flag_Type,
shape = Flag_Type
),
alpha = 0.95,
size = 3,
stroke = 1.1,
position = position_jitter(
width = 0.15,
height = 0
)
) +
scale_color_manual(
values = flag_colors,
limits = flag_levels,
drop = FALSE,
name = "QC Flag"
) +
scale_shape_manual(
values = flag_shapes,
limits = flag_levels,
drop = FALSE,
name = "QC Flag"
) +
scale_x_continuous(
breaks = sort(unique(cm_z_flux$Dist_numeric))
) +
facet_wrap(
~ Tran,
ncol = 1
) +
theme_minimal(base_size = 13) +
theme(
strip.text = element_text(face = "bold"),
legend.position = "right",
axis.title = element_text(face = "bold")
) +
labs(
title = "Sediment Flux by Distance from Marsh Edge",
subtitle = "Flagged observations are identified by color and shape",
x = "Distance from Marsh Edge (m)",
y = expression(Flux~(g/m^2))
)
flux_flags_distance
cm_z_flux <- cm_z_flux %>%
mutate(
Date.removed.from.field = as.Date(Date.removed.from.field)
)
flagged_cm <- flagged_cm %>%
mutate(
Date.removed.from.field = as.Date(Date.removed.from.field)
)
flux_flags_time <- ggplot() +
# All observations in gray
geom_point(
data = cm_z_flux,
aes(
x = Date.removed.from.field,
y = Flux
),
color = "grey75",
shape = 16,
alpha = 0.4,
size = 2,
position = position_jitter(
width = 2,
height = 0
)
) +
# Flagged observations by color and shape
geom_point(
data = flagged_cm,
aes(
